# Скопируйте в .env.local и подставьте реальный адрес бэкенда.
# Без этой переменной используется дефолт из src/lib/api.ts.
VITE_API_URL=https://aqua-uz-backend.up.railway.app/api

# Офлайн-фолбэк логина/аккаунтов (см. lib/api.ts, data/accounts.ts).
# ⚠️ Пароли демо-аккаунтов лежат открытым текстом в клиентском бандле, пока
# этот флаг включён. По умолчанию (переменная не задана) фолбэк работает
# только в `npm run dev` и ВСЕГДА выключен в `npm run build` (production).
# НЕ выставляйте "true" в .env, который используется для боевой сборки.
# VITE_ALLOW_OFFLINE_AUTH_FALLBACK=true

# Sentry — сбор клиентских ошибок в проде (см. src/lib/sentry.ts, logClientError
# в src/lib/api.ts). DSN не секретный, его можно смело коммитить/светить в бандле —
# так же, как токен Telegram WebApp SDK. Без этой переменной Sentry просто не
# инициализируется: ошибки идут только в console.error, как раньше.
# Взять DSN: sentry.io → Settings → Projects → (ваш проект) → Client Keys (DSN).
VITE_SENTRY_DSN=

# ---- Заливка sourcemaps + release tracking (см. vite.config.ts) ----
# Эти три переменные — СЕКРЕТЫ CI, а не .env.local: держите их в секретах
# пайплайна деплоя (GitHub Actions/Railway/и т.п.), не коммитьте реальные
# значения. Без них `npm run build` просто собирает бандл как обычно, без
# обращения к Sentry API — карты остаются только в dist/ локально.
#
# SENTRY_AUTH_TOKEN — sentry.io → Settings → Auth Tokens (right: project:releases + org:read)
# SENTRY_ORG        — слаг организации в Sentry
# SENTRY_PROJECT    — слаг проекта в Sentry
#
# SENTRY_RELEASE — опционально: явный id релиза (тег/номер деплоя). Если не
# задать, соберётся из `git rev-parse --short HEAD` — этого достаточно, если
# CI собирает из git-чекаута.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_RELEASE=
